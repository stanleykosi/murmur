# Environment template for the Murmur monorepo.
# Copy the variables each package needs into its local `.env` or `.env.local` file.

# apps/web
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# apps/api and apps/agents
# Local defaults assume Redis + Centrifugo are running via `infra/docker-compose.yml`.
# Replace these with Railway private-network URLs in deployed environments.
DATABASE_URL=postgresql://postgres:<password>@<supabase-session-pooler-host>:5432/postgres
REDIS_URL=redis://localhost:6379
LIVEKIT_API_KEY=lk_api_key_replace_me
LIVEKIT_API_SECRET=lk_api_secret_replace_me
LIVEKIT_URL=wss://your-project.livekit.cloud
CENTRIFUGO_API_URL=http://localhost:8000
CENTRIFUGO_API_KEY=centrifugo_api_key_replace_me
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# apps/api
CLERK_WEBHOOK_SECRET=whsec_replace_me
CENTRIFUGO_TOKEN_SECRET=centrifugo_token_secret_replace_me
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# apps/agents
OPENROUTER_API_KEY=sk-or-replace_me
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
CARTESIA_API_KEY=cartesia_replace_me
ELEVENLABS_API_KEY=elevenlabs_replace_me

# Railway Centrifugo service
CENTRIFUGO_ENGINE_REDIS_ADDRESS=redis://default:<password>@<railway-redis-private-host>:6379
CENTRIFUGO_HTTP_API_KEY=centrifugo_api_key_replace_me
CENTRIFUGO_CLIENT_TOKEN_HMAC_SECRET_KEY=centrifugo_token_secret_replace_me
CENTRIFUGO_CLIENT_ALLOWED_ORIGINS=https://murmur.app https://www.murmur.app http://localhost:3000 http://127.0.0.1:3000
