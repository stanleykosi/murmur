{
  "//": "Workspace manifest for the Murmur Fastify API scaffold.",
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify API service for Murmur, including runtime configuration, logging, Redis connectivity, and HTTP bootstrap.",
  "engines": {
    "node": ">=20.11.0 <21"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @murmur/shared build && tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "seed": "tsx src/db/seed.ts",
    "start": "node dist/server.js",
    "typecheck": "pnpm --filter @murmur/shared build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clerk/backend": "^1.26.6",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.4",
    "@murmur/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.10.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "svix": "^1.89.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
